{
  "permissions": {
    "allow": [
      "Bash(textlint *)",
      "Bash(npx markdownlint-cli2 *)",
      "Bash(npx textlint *)",
      "Bash(javac -d out/ *)",
      "Bash(java -cp out/ *)",
      "Bash(javac -d out/ *)",
      "Bash(mkdir -p /workspaces/starter-java-first-steps/out)"
    ],
    "additionalDirectories": [
      "/workspaces/starter-java-first-steps/.claude/docs/plans"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; [[ \"$f\" == *.md ]] && { markdownlint-cli2 \"$f\"; textlint \"$f\"; } || true; }"
          }
        ]
      }
    ]
  }
}
